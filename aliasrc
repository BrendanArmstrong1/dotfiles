# Aliases for terminal

alias la='exa -a --color=automatic --icons'
#alias ll='ls -alh --color=auto'
alias ll='exa -lah --color=automatic --icons'
alias lt='exa --tree --level=3 --icons'

alias df='df -h'
alias grep='grep --color'

alias yarn='yarn --use-yarnrc "$XDG_CONFIG_HOME/yarn/config"'

alias vom='vim'
alias vin='vim'
alias von='vim'

alias lf="lfub"

alias xrdb='xrdb -load ~/.config/X11/xresources'

alias im='nsxiv'

alias twit='rainbowstream'
alias cam='mpv --demuxer-lavf-format=video4linux2 --demuxer-lavf-o-set=input_format=mjpeg av://v4l2:/dev/video0'

alias cp='cp -iv'
alias fl='source findDirectory'

alias trdl='transmission-remote -a '
